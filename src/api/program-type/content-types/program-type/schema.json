{
  "kind": "collectionType",
  "collectionName": "program_types",
  "info": {
    "singularName": "program-type",
    "pluralName": "program-types",
    "displayName": "program_type"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
