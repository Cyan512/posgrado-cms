      "target": "api::program.program",
      "mappedBy": "program_type"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "link": {
      "type": "component",
      "component": "shared.link",
      "repeatable": false
    }
  }
}
