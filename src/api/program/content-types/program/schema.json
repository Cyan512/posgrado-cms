{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Programs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "program_type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program-type.program-type",
      "inversedBy": "programs"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "call": {
      "type": "boolean",
      "default": false
    },
    "mode": {
      "type": "enumeration",
      "default": "Virtual",
      "enum": [
        "Presencial",
        "Semipresencial",
        "Virtual"
      ]
    },
    "time_end": {
      "type": "date"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
